{
  "extraKnownMarketplaces": {
    "awos-marketplace": {
      "source": {
        "source": "github",
        "repo": "provectus/awos"
      }
    }
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path' | { read -r f; if [[ \"$f\" == */src/*.ts ]]; then pnpm run format \"$f\" && pnpm run lint:fix \"$f\"; fi; } 2>/dev/null || true",
            "timeout": 30,
            "statusMessage": "Formatting & linting..."
          }
        ]
      }
    ]
  }
}
