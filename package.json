{
  "name": "my_own_angularjs",
  "version": "1.0.0",
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.mjs",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.mjs",
      "require": "./dist/cjs/index.cjs",
      "types": "./dist/types/index.d.ts"
    },
    "./core": {
      "import": "./dist/esm/core/index.mjs",
      "require": "./dist/cjs/core/index.cjs",
      "types": "./dist/types/core/index.d.ts"
    },
    "./di": {
      "import": "./dist/esm/di/index.mjs",
      "require": "./dist/cjs/di/index.cjs",
      "types": "./dist/types/di/index.d.ts"
    },
    "./compiler": {
      "import": "./dist/esm/compiler/index.mjs",
      "require": "./dist/cjs/compiler/index.cjs",
      "types": "./dist/types/compiler/index.d.ts"
    },
    "./parser": {
      "import": "./dist/esm/parser/index.mjs",
      "require": "./dist/cjs/parser/index.cjs",
      "types": "./dist/types/parser/index.d.ts"
    },
    "./interpolate": {
      "import": "./dist/esm/interpolate/index.mjs",
      "require": "./dist/cjs/interpolate/index.cjs",
      "types": "./dist/types/interpolate/index.d.ts"
    }
  },
  "repository": "https://github.com/Mgrdich/my_own_angularjs.git",
  "author": "Mgrdich <mgotm13@gmail.com>",
  "license": "MIT",
  "packageManager": "pnpm@10.6.2",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "format": "prettier --write src/**/*.ts",
    "format:check": "prettier --check 'src/**/*.ts'",
    "lint:fix": "eslint --fix src/",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "vitest",
    "build": "rollup -c"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.0",
    "jsdom": "^29.0.2",
    "prettier": "^3.8.1",
    "rollup": "^4.60.1",
    "rollup-plugin-dts": "^6.4.1",
    "tslib": "^2.8.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.3"
  }
}
