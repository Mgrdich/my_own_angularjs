{
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "declaration": true,
    "declarationDir": "./dist/types",
    "outDir": "./dist",
    "rootDir": "./src",
    "importHelpers": true,
    "sourceMap": true,
    "paths": {
      "@core/*": ["./src/core/*"],
      "@parser/*": ["./src/parser/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "legacy"]
}
